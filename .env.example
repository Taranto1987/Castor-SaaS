# ─────────────────────────────────────────────────────────────────────────────
# Castor SaaS — variáveis de ambiente (exemplo)
# Fonte da verdade do backend: artifacts/api-server/src/utils/env.ts (validateEnv)
# Só DATABASE_URL e PORT são OBRIGATÓRIAS — o resto degrada com warning.
# ─────────────────────────────────────────────────────────────────────────────

# ── OBRIGATÓRIAS (servidor não sobe sem estas) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/castor_db
PORT=3000

# ── Infra / ambiente ─────────────────────────────────────────────────────────
NODE_ENV=production
DATABASE_PROVIDER=postgresql
LOG_LEVEL=info                       # pino: trace | debug | info | warn | error
# CORS allowlist (origens separadas por vírgula) — vazio = libera todas
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.vercel.app

# ── IA (chat ThallesZzz, agente, OCR de NF-e) — opcionais, degradam se faltarem ─
ANTHROPIC_API_KEY=sk-ant-xxxxx
CASTOR_AGENT_ID=agent_xxxxx
CASTOR_ENVIRONMENT_ID=env_xxxxx
# Gateway interno usado pelas libs de integração:
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxx          # chat fallback (ThallesZzz)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_GEMINI_API_KEY=xxxxx             # Gemini Vision (OCR NF-e)
AI_INTEGRATIONS_GEMINI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxx                          # usado por algumas libs OpenAI diretas

# ── WhatsApp — Evolution API (provedor primário; sem isto, follow-up NÃO envia) ─
EVOLUTION_API_URL=https://SEU_APP_EVOLUTION.up.railway.app
EVOLUTION_API_KEY=xxxxx
EVOLUTION_WEBHOOK_TOKEN=xxxxx                     # valida assinatura do webhook

# ── WhatsApp — WAHA (fallback) ───────────────────────────────────────────────
WAHA_URL=https://SEU_APP_WAHA.up.railway.app
WAHA_WEBHOOK_SECRET=xxxxx
WAHA_SESSION_NAME=castor

# ── WhatsApp — camada genérica (transport.ts), opcional ──────────────────────
WHATSAPP_PROVIDER=evolution                       # seletor (default: evolution)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE_ID=

# ── Frontend (Vite, injetadas no build) ──────────────────────────────────────
# OBS: o proxy /api/* → backend Railway já está no artifacts/castor-orcamento/vercel.json,
# então VITE_API_URL normalmente NÃO é necessário. Defina só se for apontar direto.
# VITE_API_URL=https://evolution-api-production-405f.up.railway.app
BASE_PATH=/
VITE_GTM_ID=
VITE_GA_MEASUREMENT_ID=
VITE_GOOGLE_ADS_ID=AW-
VITE_GOOGLE_ADS_CONVERSION_WHATSAPP=
SITE_URL=https://lojacastorcabofrio.com.br

# ── Domínio custom (opcional) ────────────────────────────────────────────────
RAILWAY_CUSTOM_DOMAIN=lojacastorcabofrio.com.br

# ─────────────────────────────────────────────────────────────────────────────
# REMOVIDOS de propósito (não usados no código atual — ver CLAUDE.md):
#   REDIS_URL / BullMQ  → schedulers usam setInterval; fila não é inicializada no boot
#   ZAPI_TOKEN          → sem implementação no código
# Se um dia reativar a fila, reintroduza REDIS_URL aqui.
# ─────────────────────────────────────────────────────────────────────────────
