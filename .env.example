# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/castor_db

# Redis — used by BullMQ job queues (optional in dev; required in production)
REDIS_URL=redis://localhost:6379

# Logging — pino level: trace | debug | info | warn | error
LOG_LEVEL=info

# Server Configuration
PORT=3000
NODE_ENV=production

# Security — CORS allowlist (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.vercel.app

# AI Integrations
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# WhatsApp Integration (Z-API)
ZAPI_TOKEN=xxxxx

# Optional: Custom Domain
RAILWAY_CUSTOM_DOMAIN=lojacastorcabofrio.com.br

# Internal AI Gateway (used by integration libraries)
AI_INTEGRATIONS_GEMINI_API_KEY=xxxxx
AI_INTEGRATIONS_GEMINI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=xxxxx
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Castor Managed Agent
CASTOR_AGENT_ID=agent_011CaUZvcdTX3LxfnopZE9Cw
CASTOR_ENVIRONMENT_ID=env_0111U769QLZaYYpabKFRacWM

# WhatsApp via WAHA (https://github.com/devlikeapro/waha — deploy no Railway)
WAHA_URL=https://SEU_APP_WAHA.up.railway.app
WAHA_SESSION_NAME=castor
# SEO & Analytics
VITE_GOOGLE_ADS_ID=AW-
VITE_GOOGLE_ADS_CONVERSION_WHATSAPP=
SITE_URL=https://lojacastorcabofrio.com.br
